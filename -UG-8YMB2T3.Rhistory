library(brms)
library(ggplot2)
library(here)
visualise_AGB_DBH_allometry_data <- function(path){
#read data
data <- read.csv(path)
print(path)
#transform data
data$method <- factor(data$method, c("manual", "rct","rct_keep"))
data <- data[data$method == "manual",]
data <- cbind(data,
data.frame("V_m3.log" = log(data$V_m3),
"H_m.log" = log(data$H_m),
"DBH_cm.log" = log(data$DBH_cm),
"DBH_cm.log2" = log(data$DBH_cm) ^ 2
))
#plot data
print(fig <- ggplot(data, aes(
x = DBH_cm.log, y = V_m3.log, colour = method
)) +
geom_point() +
theme_bw() +
#title()
scale_color_manual(
values = c("manual" = "blue", "rct" = "red", "rct_keep" = "green"),
labels = c("manual" = "manual", "rct" = "rct", "rct_keep" = "rct_keep")
))
}
