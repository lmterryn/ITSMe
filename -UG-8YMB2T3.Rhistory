path_highres <- paste0("//wsl.localhost/Ubuntu/home/lmterryn/EucFACE/output_treeinfo/combined/2022_", i, "-detailed_raycloud_trees_info_gradient_",gradient,".txt")
if (file.exists(path_lowres) & file.exists(path_highres)){
qsm_lowres  <- read_rct_qsm_b(path = path_lowres)
qsm_highres <- read_rct_qsm_b(path = path_highres)
tree_id <- paste0("2022_", i)
# ---- TREE LEVEL ----
tree_results[[length(tree_results)+1]] <- data.frame(
tree_id = tree_id,
V_low  = qsm_lowres$qsm_1$treedata$TotalVolume,
V_high = qsm_highres$qsm_1$treedata$TotalVolume
)
# ---- BIN LEVEL ----
df_tree <- data.frame(
tree_id = tree_id,
bin = labels,
V_low = NA,
V_high = NA
)
for (b in seq_along(labels)){
lower <- breaks[b]
upper <- breaks[b+1]
idx_low  <- qsm_lowres$qsm_1$cylinder$diameter  >= lower & qsm_lowres$qsm_1$cylinder$diameter  < upper
idx_high <- qsm_highres$qsm_1$cylinder$diameter >= lower & qsm_highres$qsm_1$cylinder$diameter < upper
df_tree$V_low[b]  <- sum(qsm_lowres$qsm_1$cylinder$volume[idx_low], na.rm = TRUE)
df_tree$V_high[b] <- sum(qsm_highres$qsm_1$cylinder$volume[idx_high], na.rm = TRUE)
}
